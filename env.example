# DeepSeek API Configuration
# Get your API key at: https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-chat

# Admitad Affiliate Configuration (optional if using Partnerize)
# NEXT_PUBLIC_ADMITAD_W_ID=your_ad_space_id
# NEXT_PUBLIC_ADMITAD_C_ID=your_campaign_id

# Partnerize — iHerb program (works without Admitad). Camref from Partnerize publisher dashboard.
# NEXT_PUBLIC_PARTNERIZE_CAMREF=your_camref_here

# Optional: Apify (https://apify.com) — paid third-party runs for scripts/sync-catalog-apify.ts
# You must comply with iHerb Terms of Use and Apify terms when syncing.
# APIFY_TOKEN=
# APIFY_ACTOR_ID=vaunted~iherb-scraper
# CATALOG_MAX_PER_CATEGORY=30
# CATALOG_TOTAL_CAP=300

# Site URL — canonical base for sitemap, robots, and meta. Use https://swiftherb.com for production
# deploys; http://localhost:3000 for local dev only.
NEXT_PUBLIC_SITE_URL=https://swiftherb.com

# Optional: www → apex (scripts/ensure-www-redirect-rule.ts, `pnpm cf:www-redirect`). Not used by Next.js.
# API token: Zone > Single Redirect > Edit (same Cloudflare account as Wrangler).
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ZONE_ID=
# CLOUDFLARE_ZONE_NAME=swiftherb.com

# Cloudflare Workers API Configuration (Optional)
# Set this to your deployed Workers URL for production
# Leave empty for local development (will use mock data)
NEXT_PUBLIC_WORKERS_API_URL=https://swiftherb-api.your-subdomain.workers.dev

# For local Workers development
WORKERS_API_URL=http://localhost:8787
