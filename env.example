# DeepSeek API Configuration
# Get your API key at: https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-chat

# Admitad Affiliate Configuration
# Add these when you have them from Admitad dashboard:
# NEXT_PUBLIC_ADMITAD_W_ID=your_ad_space_id
# NEXT_PUBLIC_ADMITAD_C_ID=your_campaign_id

# Site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Cloudflare Workers API Configuration (Optional)
# Set this to your deployed Workers URL for production
# Leave empty for local development (will use mock data)
NEXT_PUBLIC_WORKERS_API_URL=https://swiftherb-api.your-subdomain.workers.dev

# For local Workers development
WORKERS_API_URL=http://localhost:8787
